{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git rev-parse:*)",
      "Bash(git remote:*)",
      "Bash(git config --get:*)",
      "Bash(git config --list:*)",
      "Bash(git ls-files:*)",
      "Bash(git worktree list:*)",
      "Bash(git stash list:*)",
      "Bash(git blame:*)",
      "Bash(git fetch:*)",
      "Bash(git pull --ff-only:*)",

      "Bash(gh auth status:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh pr status:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh run watch:*)",
      "Bash(gh repo view:*)",
      "Bash(gh repo list:*)",
      "Bash(gh project list:*)",
      "Bash(gh project view:*)",
      "Bash(gh project item-list:*)",
      "Bash(gh release list:*)",
      "Bash(gh release view:*)",
      "Bash(gh label list:*)",
      "Bash(gh search:*)",
      "Bash(gh workflow list:*)",
      "Bash(gh workflow view:*)",

      "Bash(docker ps:*)",
      "Bash(docker images:*)",
      "Bash(docker logs:*)",
      "Bash(docker inspect:*)",
      "Bash(docker compose ps:*)",
      "Bash(docker compose logs:*)",
      "Bash(docker version:*)",
      "Bash(docker info:*)",

      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(jq:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(tree:*)",
      "Bash(which:*)"
    ],

    "deny": [
      "Bash(git push origin main)",
      "Bash(git push origin main:*)",
      "Bash(git push origin HEAD:main:*)",
      "Bash(git push :main:*)",
      "Bash(git push -f:*)",
      "Bash(git push --force:*)",

      "Bash(rm -rf /:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf ~/:*)"
    ]
  },

  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-edit-reminders.sh"
          }
        ]
      }
    ]
  }
}
